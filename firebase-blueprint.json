{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A construction project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "developer": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sheetUrl": { "type": "string" },
        "isHot": { "type": "boolean" },
        "isFavorite": { "type": "boolean" }
      },
      "required": ["id", "name", "developer", "location", "type", "status", "imageUrl", "isHot", "isFavorite"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "gender": { "type": "string" },
        "workLocation": { "type": "string" },
        "referrer": { "type": "string" }
      },
      "required": ["id", "name", "role", "email", "status", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite project.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["uid", "projectId"]
    },
    "UserHistory": {
      "title": "User History",
      "description": "Log of user interactions with units.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "projectId": { "type": "string" },
        "unitCode": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "action", "projectId", "unitCode", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "Project" },
      "description": "Collection of projects."
    },
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Collection of users."
    },
    "/favorites/{favoriteId}": {
      "schema": { "$ref": "Favorite" },
      "description": "Collection of favorite projects."
    },
    "/user_history/{historyId}": {
      "schema": { "$ref": "UserHistory" },
      "description": "Collection of user interaction logs."
    }
  }
}
