rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - developer: string (required)
    //   - location: string (required)
    //   - type: string (required)
    //   - status: string (required)
    //   - imageUrl: string (required)
    //   - sheetUrl: string (optional)
    //   - isHot: boolean (required)
    //   - isFavorite: boolean (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - role: string (required)
    //   - phone: string (optional)
    //   - email: string (required)
    //   - avatarUrl: string (optional)
    //
    // Collection: favorites
    // Document ID: {favoriteId}
    // Fields:
    //   - uid: string (required)
    //   - projectId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tranthetrong91@gmail.com"));
    }

    function isManager() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSuperAdmin() || role == 'manager';
    }

    function isSales() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isManager() || role == 'sales';
    }

    function isPending() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'pending';
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /system_config/{configId} {
      allow read, write: if isSuperAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && !isPending();
      allow create, update, delete: if isManager();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create: if isOwner(userId) && hasRequiredFields(['id', 'name', 'role', 'email', 'status', 'createdAt']);
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.uid) || isSuperAdmin();
      allow create: if isOwner(request.resource.data.uid) && hasRequiredFields(['uid', 'projectId']);
      allow update: if isOwner(resource.data.uid) || isSuperAdmin();
      allow delete: if isOwner(resource.data.uid) || isSuperAdmin();
    }

    match /user_history/{historyId} {
      allow read: if isOwner(resource.data.uid) || isSuperAdmin();
      allow create: if isOwner(request.resource.data.uid) && hasRequiredFields(['uid', 'action', 'details', 'timestamp']);
      allow update, delete: if isSuperAdmin();
    }
  }
}
