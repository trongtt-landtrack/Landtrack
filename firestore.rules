rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - developer: string (required)
    //   - location: string (required)
    //   - type: string (required)
    //   - status: string (required)
    //   - imageUrl: string (required)
    //   - sheetUrl: string (optional)
    //   - isHot: boolean (required)
    //   - isFavorite: boolean (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - role: string (required)
    //   - phone: string (optional)
    //   - email: string (required)
    //   - avatarUrl: string (optional)
    //   - status: string (required)
    //   - createdAt: string (required)
    //
    // Collection: favorites
    // Document ID: {favoriteId}
    // Fields:
    //   - uid: string (required)
    //   - projectId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "tranthetrong91@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
             : 'none';
    }

    function isManagement() {
      let role = getUserRole();
      return isSuperAdmin() || role == 'project_director';
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /system_config/{configId} {
      allow read, write: if isSuperAdmin();
    }

    match /allowed_phones/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isManagement();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      
      function isValidUser() {
        return hasRequiredFields(['id', 'name', 'role', 'email', 'status', 'createdAt']) &&
               hasOnlyAllowedFields(['id', 'name', 'role', 'email', 'status', 'createdAt', 'phone', 'avatarUrl', 'gender', 'workLocation', 'referrer']) &&
               isValidString('id', 1, 100) &&
               isValidString('name', 1, 100) &&
               isValidString('role', 1, 50) &&
               isValidString('email', 5, 100) &&
               isValidString('status', 1, 50) &&
               isValidString('createdAt', 1, 50) &&
               (!('phone' in request.resource.data) || isValidString('phone', 0, 20)) &&
               (!('avatarUrl' in request.resource.data) || isValidString('avatarUrl', 0, 500)) &&
               (!('gender' in request.resource.data) || isValidString('gender', 0, 20)) &&
               (!('workLocation' in request.resource.data) || isValidString('workLocation', 0, 100)) &&
               (!('referrer' in request.resource.data) || isValidString('referrer', 0, 100));
      }

      allow create: if isOwner(userId) 
                    && isValidUser()
                    && (request.resource.data.role == 'user' || (request.resource.data.role == 'super_admin' && request.auth.token.email == 'tranthetrong91@gmail.com'));
                    
      allow update: if isSuperAdmin() || 
                    (isOwner(userId) 
                     && isValidUser()
                     && isImmutable('id')
                     && isImmutable('email')
                     && isImmutable('createdAt')
                     && request.resource.data.role == resource.data.role
                     && request.resource.data.status == resource.data.status);
                     
      allow delete: if isSuperAdmin();
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isSuperAdmin());
      
      function isValidFavorite() {
        return hasRequiredFields(['uid', 'projectId', 'timestamp']) &&
               hasOnlyAllowedFields(['uid', 'projectId', 'unitCode', 'timestamp']) &&
               request.resource.data.uid == request.auth.uid &&
               isValidString('projectId', 1, 100) &&
               (!('unitCode' in request.resource.data) || (request.resource.data.unitCode is string && request.resource.data.unitCode.size() <= 100)) &&
               request.resource.data.timestamp is timestamp;
      }

      allow create: if isAuthenticated() && isValidFavorite();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.uid) && isValidFavorite() && isImmutable('uid') && isImmutable('timestamp');
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isSuperAdmin());
    }

    match /user_history/{historyId} {
      allow read: if isOwner(resource.data.uid) || isSuperAdmin();
      
      function isValidHistory() {
        return hasRequiredFields(['uid', 'action', 'projectId', 'unitCode', 'timestamp']) &&
               request.resource.data.uid == request.auth.uid &&
               isValidString('action', 1, 50) &&
               isValidString('projectId', 1, 100) &&
               isValidString('unitCode', 1, 100) &&
               request.resource.data.timestamp is timestamp;
      }

      allow create: if isOwner(request.resource.data.uid) && isValidHistory();
      allow update, delete: if isSuperAdmin();
    }
  }
}
